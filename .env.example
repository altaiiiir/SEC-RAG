# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edgar_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501

# Embeddings & chunking
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
TABLE_ROW_CHUNK_SIZE=15
ENABLE_SENTENCE_BOUNDARIES=true

# Indexer performance (increase EMBED_BATCH_SIZE if you have a GPU)
EMBED_BATCH_SIZE=256
EMBED_BATCH_FILES=8

# Ollama - we can call an API instead of using the local model
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3.5:4b

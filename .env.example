# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edgar_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Chunking Configuration
MIN_CHUNK_SIZE=100
TABLE_ROW_CHUNK_SIZE=5
TABLE_PRESERVE_HEADER=true
MIN_TABLE_ROWS=3
MIN_LIST_ITEMS=2
ENABLE_ADAPTIVE_CHUNKING=true
ENABLE_SENTENCE_BOUNDARIES=true
ENABLE_TABLE_DETECTION=true
ENABLE_LIST_DETECTION=true
ENABLE_SEMANTIC_OVERLAP=false
ENABLE_NLP_DETECTION=false
OVERLAP_STRATEGY=fixed

# Ollama - we can call an API instead of using the local model
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3.5:4b
